@startuml LogisTEC_Architecture
skinparam backgroundColor #f5f5f5
skinparam roundcorner 10
skinparam classBorderColor #333

' CAPA 1: TDAs
package util {
    class LinkedList_T {
        - head: Node
        - tail: Node
        - size: int
        + addLast(item: T)
        + addFirst(item: T)
        + removeFirst(): T
        + remove(i: int): T
        + get(i: int): T
        + contains(item: T): boolean
        + size(): int
        + isEmpty(): boolean
        + toArray(): T[]
    }

    class MinHeap_T {
        - heap: Entry[]
        - size: int
        + insert(item: T, key: double)
        + extractMin(): T
        + peekMin(): T
        + decreaseKey(item: T, newKey: double)
        + getKey(item: T): double
        + contains(item: T): boolean
    }

    class UnionFind {
        - parent: int[]
        - rank: int[]
        - components: int
        + find(x: int): int
        + union(x: int, y: int): boolean
        + connected(x: int, y: int): boolean
        + components(): int
    }

    class Queue_T {
        - list: LinkedList
        + enqueue(item: T)
        + dequeue(): T
        + peek(): T
        + isEmpty(): boolean
    }

    class Stack_T {
        - list: LinkedList
        + push(item: T)
        + pop(): T
        + peek(): T
        + isEmpty(): boolean
    }
}

' CAPA 2: Dominio - Grafo
package graph {
    enum VertexType {
        DEPOT
        INTERSECTION
        DELIVERY
    }

    class Vertex {
        - id: String
        - type: VertexType
        - x: int
        - y: int
        + getId(): String
        + getType(): VertexType
        + getX(): int
        + getY(): int
        + isDepot(): boolean
        + isDelivery(): boolean
    }

    class Edge {
        - u: int
        - v: int
        - weight: int
        + getU(): int
        + getV(): int
        + getWeight(): int
        + other(vertex: int): int
        + compareTo(o: Edge): int
    }

    class AdjEntry {
        - target: int
        - weight: int
        + AdjEntry(target, weight)
    }

    class Graph {
        - vertices: Vertex[]
        - adj: LinkedList[]
        - edges: LinkedList
        - V: int
        - E: int
        - depotIndex: int
        + addVertex(index: int, v: Vertex)
        + addEdge(u: int, v: int, weight: int)
        + indexOf(id: String): int
        + numVertices(): int
        + numEdges(): int
        + getVertex(i: int): Vertex
        + getDepotIndex(): int
        + adj(v: int): LinkedList
        + getAllEdges(): LinkedList
        + adjacencyMatrix(): int[][]
        + booleanMatrix(): boolean[][]
    }

    class Truck {
        - id: String
        - capacity: int
        - currentLoad: int
        - packages: LinkedList
        - route: LinkedList
        - expandedRoute: LinkedList
        - routeDistanceNN: int
        - routeDistanceMST: int
        + getId(): String
        + getCapacity(): int
        + getCurrentLoad(): int
        + getFreeCapacity(): int
        + getPackages(): LinkedList
        + getRoute(): LinkedList
        + getExpandedRoute(): LinkedList
        + addPackage(p: Parcel): boolean
        + canFit(p: Parcel): boolean
        + occupancyPercent(): double
    }
}

' CAPA 2b: Dominio - Paquetes
package algorithms {
    enum ParcelStatus {
        PENDING
        ASSIGNED
        REJECTED
    }

    class Parcel {
        - id: String
        - destinationId: String
        - destinationIndex: int
        - weight: int
        - priority: int
        - status: ParcelStatus
        - assignedTruck: String
        + getId(): String
        + getDestinationId(): String
        + getDestinationIndex(): int
        + setDestinationIndex(i: int)
        + getWeight(): int
        + getPriority(): int
        + getStatus(): ParcelStatus
        + getAssignedTruck(): String
        + assign(truckId: String)
        + reject()
    }
}

' CAPA 3: Algoritmos
package algorithms {
    class Dijkstra {
        - src: int
        - V: int
        - dist: int[]
        - prev: int[]
        + Dijkstra(g: Graph, src: int)
        + distanceTo(dst: int): int
        + hasPath(dst: int): boolean
        + pathTo(dst: int): LinkedList
        + getDistances(): int[]
        + resultToString(g: Graph, dst: int): String
    }

    class FloydWarshall {
        - V: int
        - dist: int[][]
        - next: int[][]
        + FloydWarshall(g: Graph)
        + dist(u: int, v: int): int
        + reconstructPath(u: int, v: int): int[]
        + getDistMatrix(): int[][]
    }

    class Warshall {
        - V: int
        - reach: boolean[][]
        + Warshall(g: Graph)
        + canReach(u: int, v: int): boolean
        + getReachMatrix(): boolean[][]
    }

    class Kruskal {
        - mstEdges: LinkedList
        - totalWeight: int
        - elapsedNano: long
        + Kruskal(g: Graph)
        + getMSTEdges(): LinkedList
        + getTotalWeight(): int
        + getElapsedMs(): double
        + buildMSTGraph(V: int): Graph
    }

    class Prim {
        - V: int
        - mstEdges: LinkedList
        - totalWeight: int
        + Prim(g: Graph, src: int)
        + getMSTEdges(): LinkedList
        + getTotalWeight(): int
        + buildMSTGraph(V: int): Graph
    }

    class GraphTraversal {
        + {static} dfsPreorder(g: Graph, src: int, visited: boolean[], result: LinkedList)
        + {static} bfsOrder(g: Graph, src: int): LinkedList
    }
}

' CAPA 4: Planner (Orquestador)
package planner {
    class Planner {
        - graph: Graph
        - fw: FloydWarshall
        - warshall: Warshall
        - depotIdx: int
        + Planner(graph, fw, warshall)
        + validateReachability(packages: LinkedList): LinkedList
        + assignPackages(packages: LinkedList, trucks: LinkedList): LinkedList
        + planRoutes(trucks: LinkedList)
        + nearestNeighbor(stops: int[]): int[]
        + mstBased(stops: int[]): int[]
        + routeDistance(route: int[]): int
    }
}

' CAPA 5: I/O
package io {
    class CityLoader {
        + {static} loadCityData(graphPath, parcelsPath, trucksPath)
    }

    class JsonParser {
        + {static} parseJson(jsonStr): Object
    }

    class ReportGenerator {
        + {static} generateReport(trucks, parcels): String
    }
}

' CAPA 5b: UI
package ui {
    class MainWindow {
        - frame: JFrame
        - graphPanel: GraphPanel
        - graph: Graph
        - trucks: LinkedList
        - parcels: LinkedList
        + MainWindow(title, width, height)
        + setGraph(g: Graph)
        + setTrucks(trucks: LinkedList)
        + setParcels(parcels: LinkedList)
        + showReport(report: String)
    }

    class GraphPanel {
        - graph: Graph
        - trucks: LinkedList
        - zoom: double
        + GraphPanel(graph: Graph)
        + setTrucks(trucks: LinkedList)
        + paintComponent(g: Graphics)
    }
}

' Punto de entrada
class Main {
    + {static} main(args: String[])
}

' ============================================================================
' RELACIONES
' ============================================================================

' TDAs
Queue_T --> LinkedList_T: usa
Stack_T --> LinkedList_T: usa

' Graph y Vertex/Edge
Graph --> Vertex: contiene
Graph --> Edge: contiene
Graph --> LinkedList_T: usa (adj)
Graph --> AdjEntry: contiene

' Truck y Parcel
Truck --> LinkedList_T: packages
Truck --> LinkedList_T: route

' Algoritmos con Graph
Dijkstra --> Graph: analiza
Dijkstra --> MinHeap_T: usa
FloydWarshall --> Graph: analiza
Warshall --> Graph: analiza
Kruskal --> Graph: analiza
Kruskal --> UnionFind: usa
Kruskal --> Edge: ordena
Prim --> Graph: analiza
Prim --> MinHeap_T: usa
GraphTraversal --> Graph: analiza

' Planner
Planner --> Graph: usa
Planner --> FloydWarshall: usa
Planner --> Warshall: usa
Planner --> Truck: planifica
Planner --> Parcel: valida
Planner --> Kruskal: usa
Planner --> GraphTraversal: usa

' I/O
CityLoader --> Graph: construye
CityLoader --> Parcel: construye
CityLoader --> JsonParser: usa
ReportGenerator --> Truck: reporta

' UI
MainWindow --> GraphPanel: contiene
MainWindow --> Graph: muestra
MainWindow --> Truck: visualiza
GraphPanel --> Graph: dibuja

' Main
Main --> CityLoader: usa
Main --> Planner: ejecuta
Main --> FloydWarshall: crea
Main --> Warshall: crea
Main --> MainWindow: muestra

@enduml
